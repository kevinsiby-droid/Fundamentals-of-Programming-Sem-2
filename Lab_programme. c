#include <stdio.h>
#include <string.h>

struct Student {
    int roll;
    char name[30];
    int marks;
};

// Function for Alphabetical Sort (by Name)
void sortByName(struct Student s[], int n) {
    struct Student temp;
    for(int i = 0; i < n - 1; i++) {
        for(int j = 0; j < n - i - 1; j++) {
            if(strcmp(s[j].name, s[j+1].name) > 0) {
                temp = s[j]; s[j] = s[j+1]; s[j+1] = temp;
            }
        }
    }
}

