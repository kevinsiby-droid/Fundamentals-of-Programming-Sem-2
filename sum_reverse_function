#include <stdio.h>
void sum(int n);
void reverse(int n);
int main()
{
    int n,s,d,rev;
    printf("enter a number :");
    scanf("%d",&n);
    sum(n);
    reverse(n);
    return 0;
}
void sum(int n)
{
    int s=0,d;
    while(n!=0)
    {
        d=n%10;
        s=s+d;
        n=n/10; 
    }
    printf("sum of digit of the number is %d",s);
}
void reverse(int n)
{
    int d,rev=0;
    while(n!=0)
    {
        d=n%10;
        rev=rev*10+d;
        n=n/10;
    }
    printf("\nreverse of the number is %d",rev);
}
