#include <stdio.h>
void main() {
    int i,a[100],n,j,temp;
    printf("write the number of elements ");
    scanf("%d",&n);
    printf("write elements");
    for (i=0;i<n;i++)
    {
        scanf("%d",&a[i]);
    }
    for(i=0;i<n;i++)
    {
        for(j=0;j<n-i-1;j++)
        {
            if(a[j]>a[j+1])
            {
                temp=a[j+1];
                a[j+1]=a[j];
                a[j]=temp;
            }
        }
   
    }
    for(i=0;i<n;i++){
        printf("%d ",a[i]);
    }
}
