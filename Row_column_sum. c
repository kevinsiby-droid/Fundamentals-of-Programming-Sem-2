#include <stdio.h>

int main() {
    int mat[100][100], i, j,m, n, sum;
    printf("enter the limit of rows and columns");
    scanf("%d %d", &m, &n);

    printf("Enter elements for a 3x3 matrix:\n");
    for(i = 0; i < m; i++) {
        for(j = 0; j < n; j++) {
            scanf("%d", &mat[i][j]);
        }
    }

    // Row Sum
    for(i = 0; i < m; i++) {
        sum = 0;
        for(j = 0; j < n; j++) {
            sum += mat[i][j];
        }
        printf("Sum of Row %d: %d\n", i + 1, sum);
    }

    // Column Sum
    for(j = 0; j < n; j++) {
        sum = 0;
        for(i = 0; i < m; i++) {
            sum += mat[i][j];
        }
        printf("Sum of Column %d: %d\n", j + 1, sum);
    }

    return 0;
}
