#include <stdio.h>
void main() {
    int i,a[100],n,found=0,c,p;
    printf("write the number of elements ");
    scanf("%d",&n);
    printf("write elements");
    for (i=0;i<n;i++)
    {
        scanf("%d",&a[i]);
    }
    printf("enter element to search");
    scanf("%d",&c);
    for(i=0;i<n;i++)
    {
        if(a[i]==c)
        {
            found=1;
            p=i;
            break;
        }
        
    }
    if(found==1)
    {
        printf("element %d was found in position %d ",c,p+1 );
    }
    else if(found==0)
    {
        printf("element not found");
    }
}
